# Игнорировать все кэши Python (во всех директориях)
__pycache__/
*.pyc
*.pyo
*.pyd

# Игнорировать локальное виртуальное окружение (uv)
.venv/

# Игнорировать настройки IDE и редакторов
.idea/
.zed/
.vscode/

# Игнорировать логи и кэши линтеров
.ruff_cache/
.pytest_cache/
*.log

# Игнорировать директорию Git
.git/
db.sqlite3
db.*
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal
data/